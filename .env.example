# Copy to `.env` and fill with strong random values before any non-local use.
# docker-compose reads this file automatically.
#
# Generate values, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# Fernet/AES key used to encrypt stored Git tokens & AI API keys.
# MUST stay identical between the api and worker services.
ENCRYPTION_KEY=

# Application secret (signing / general crypto).
SECRET_KEY=
